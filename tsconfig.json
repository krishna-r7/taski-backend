{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "types": ["node"],
    "lib": ["ES2022"],

    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}